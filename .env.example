# ─── Database (SQLite — schema: packages/database/prisma/schema.prisma) ───
# Prisma resolves relative paths from the schema file location.
DATABASE_URL="file:./dev.db"

# ─── JWT (production: use long random strings!) ───
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_REFRESH_SECRET="change-me-refresh-secret-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── API ───
API_PORT=4000
API_URL="http://localhost:4000"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,https://dnzmedya.com,https://www.dnzmedya.com,https://admin.dnzmedya.com"

# ─── Web (Public Site) — browser-visible URLs ───
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="DNZMEDYA"

# ─── Admin Panel ───
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"

# ─── Storage ───
STORAGE_DRIVER="local"
STORAGE_LOCAL_PATH="./uploads"
STORAGE_PUBLIC_URL="http://localhost:4000/uploads"

# ─── Docker first deploy only ───
RUN_SEED=false

# ─── Admin Seed (change before production!) ───
SEED_ADMIN_EMAIL="admin@dnzmedya.com"
SEED_ADMIN_PASSWORD="Admin123!"

# ─── AI Chat (optional) ───
AI_PROVIDER="groq"
GROQ_API_KEY=""
AI_MODEL="llama-3.1-8b-instant"
AI_BASE_URL="https://api.groq.com/openai/v1"

# ─── Production example (uncomment & edit) ───
# NEXT_PUBLIC_API_URL="https://api.dnzmedya.com"
# NEXT_PUBLIC_SITE_URL="https://dnzmedya.com"
# NEXT_PUBLIC_ADMIN_URL="https://admin.dnzmedya.com"
# STORAGE_PUBLIC_URL="https://api.dnzmedya.com/uploads"
# CORS_ORIGINS="https://dnzmedya.com,https://www.dnzmedya.com,https://admin.dnzmedya.com"
